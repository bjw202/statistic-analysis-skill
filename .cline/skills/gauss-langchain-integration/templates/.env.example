# Gauss LLM 환경변수 설정 파일
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요:
#   cp .env.example .env
#
# .env 파일은 절대 git에 커밋하지 마세요! (.gitignore에 추가)

# Gauss API 엔드포인트
GAUSS_ENDPOINT=http://gauss-internal.company.com

# 클라이언트 인증 키 (x-generative-ai-client 헤더)
GAUSS_CLIENT_KEY=your-client-key

# 패스 키 (x-openapi-koten 헤더)
GAUSS_PASS_KEY=your-pass-key

# 사용자 이메일 (x-generative-ai-user-email 헤더)
GAUSS_EMAIL=user@company.com

# 사용할 모델 ID
GAUSS_MODEL_ID=your-model-id
